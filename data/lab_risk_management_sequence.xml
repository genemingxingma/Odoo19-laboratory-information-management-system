<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_lab_risk_register" model="ir.sequence">
        <field name="name">Lab Risk Register</field>
        <field name="code">lab.risk.register</field>
        <field name="prefix">RSK%(y)s%(month)s-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_lab_medical_waste_batch" model="ir.sequence">
        <field name="name">Lab Medical Waste Batch</field>
        <field name="code">lab.medical.waste.batch</field>
        <field name="prefix">WST%(y)s%(month)s-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
