<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_lab_pathology_case" model="ir.sequence">
        <field name="name">Pathology Case</field>
        <field name="code">lab.pathology.case</field>
        <field name="prefix">PTH/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_lab_pathology_specimen" model="ir.sequence">
        <field name="name">Pathology Specimen</field>
        <field name="code">lab.pathology.specimen</field>
        <field name="prefix">SPM/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_lab_pathology_slide" model="ir.sequence">
        <field name="name">Pathology Slide</field>
        <field name="code">lab.pathology.slide</field>
        <field name="prefix">SLD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
