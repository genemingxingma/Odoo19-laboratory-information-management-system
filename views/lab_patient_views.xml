<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_patient_list" model="ir.ui.view">
        <field name="name">lab.patient.list</field>
        <field name="model">lab.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="identifier"/>
                <field name="birthdate"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="insurance_provider"/>
                <field name="insurance_no"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_patient_form" model="ir.ui.view">
        <field name="name">lab.patient.form</field>
        <field name="model">lab.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="identifier"/>
                            <field name="birthdate"/>
                            <field name="gender"/>
                            <field name="lang"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="active"/>
                            <field name="insurance_provider"/>
                            <field name="insurance_no"/>
                            <field name="informed_consent_signed"/>
                            <field name="informed_consent_date"/>
                        </group>
                    </group>
                    <group string="Address">
                        <group>
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="zip"/>
                            <field name="country"/>
                        </group>
                    </group>
                    <group string="Emergency Contact">
                        <group>
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_phone"/>
                        </group>
                        <group>
                            <field name="emergency_contact_relation"/>
                        </group>
                    </group>
                    <group string="Clinical">
                        <group>
                            <field name="pregnancy_status"/>
                            <field name="breastfeeding"/>
                        </group>
                        <group>
                            <field name="allergy_history"/>
                            <field name="past_medical_history"/>
                            <field name="medication_history"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lab_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">lab.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lab_patient"
              name="Patients"
              parent="menu_lab_master_data_root"
              action="action_lab_patient"
              sequence="44"/>
</odoo>
