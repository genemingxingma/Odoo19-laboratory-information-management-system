<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_pathology_case_list" model="ir.ui.view">
        <field name="name">lab.pathology.case.list</field>
        <field name="model">lab.pathology.case</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state"/>
                <field name="sample_id"/>
                <field name="patient_id"/>
                <field name="client_id"/>
                <field name="priority"/>
                <field name="specimen_count"/>
                <field name="slide_count"/>
                <field name="image_count"/>
                <field name="reviewed_by_id"/>
                <field name="signed_by_id"/>
                <field name="reported_at"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_lab_pathology_case_form" model="ir.ui.view">
        <field name="name">lab.pathology.case.form</field>
        <field name="model">lab.pathology.case</field>
        <field name="arch" type="xml">
            <form string="Pathology Case">
                <header>
                    <button name="action_set_accessioned" type="object" string="Accession" invisible="state in ('accessioned','grossing','microscopy','diagnosed','reviewed','reported','cancelled')"/>
                    <button name="action_set_grossing" type="object" string="Grossing" invisible="state in ('grossing','microscopy','diagnosed','reviewed','reported','cancelled')"/>
                    <button name="action_set_microscopy" type="object" string="Microscopy" invisible="state in ('microscopy','diagnosed','reviewed','reported','cancelled')"/>
                    <button name="action_set_diagnosed" type="object" string="Diagnosed" class="btn-primary" invisible="state in ('diagnosed','reviewed','reported','cancelled')"/>
                    <button name="action_set_reviewed" type="object" string="Reviewed" invisible="state in ('reviewed','reported','cancelled')"/>
                    <button name="action_release_report" type="object" string="Release Report" class="btn-primary" invisible="state in ('reported','cancelled')"/>
                    <button name="action_print_report" type="object" string="Print Pathology Report" invisible="state != 'reported'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('reported','cancelled')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state == 'reported'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,accessioned,grossing,microscopy,diagnosed,reviewed,reported,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_specimens" icon="fa-flask">
                            <field name="specimen_count" widget="statinfo" string="Specimens"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_images" icon="fa-image">
                            <field name="image_count" widget="statinfo" string="Images"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="sample_id" readonly="1"/>
                            <field name="request_id" readonly="1"/>
                            <field name="patient_id" readonly="1"/>
                            <field name="client_id" readonly="1"/>
                            <field name="physician_name" readonly="1"/>
                            <field name="accession_barcode" readonly="1"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="pathology_type"/>
                            <field name="diagnosis_category"/>
                            <field name="icd_o_code"/>
                            <field name="tnm_stage"/>
                            <field name="tumor_grade"/>
                            <field name="specimen_received_at"/>
                            <field name="gross_examined_at"/>
                            <field name="microscopic_examined_at"/>
                            <field name="diagnosis_at" readonly="1"/>
                            <field name="reviewed_at" readonly="1"/>
                            <field name="reported_at" readonly="1"/>
                            <field name="reviewed_by_id" readonly="1"/>
                            <field name="signed_by_id" readonly="1"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pathology Report">
                            <group>
                                <field name="clinical_history" widget="html"/>
                                <field name="gross_description" widget="html"/>
                                <field name="microscopic_description" widget="html"/>
                                <field name="final_diagnosis" widget="html"/>
                                <field name="interpretation_comment" widget="html"/>
                                <field name="recommendation"/>
                                <field name="synoptic_summary" readonly="1"/>
                                <field name="ready_for_signoff" readonly="1"/>
                            </group>
                        </page>
                        <page string="Specimens">
                            <field name="specimen_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="specimen_type"/>
                                    <field name="specimen_site"/>
                                    <field name="container_no"/>
                                    <field name="fixative"/>
                                    <field name="collected_at"/>
                                    <field name="received_at"/>
                                    <field name="cassette_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Images">
                            <field name="image_ids" context="{'default_case_id': id, 'default_company_id': company_id}">
                                <kanban>
                                    <field name="name"/>
                                    <field name="image_1920"/>
                                    <field name="magnification"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click">
                                                <div class="mb-2"><strong><field name="name"/></strong></div>
                                                <div class="mb-2"><img t-att-src="kanban_image('lab.pathology.image', 'image_1920', record.id.raw_value)" alt="Pathology" style="max-width: 100%; max-height: 180px;"/></div>
                                                <div><field name="magnification"/></div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lab_pathology_specimen_list" model="ir.ui.view">
        <field name="name">lab.pathology.specimen.list</field>
        <field name="model">lab.pathology.specimen</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="case_id"/>
                <field name="specimen_type"/>
                <field name="specimen_site"/>
                <field name="container_no"/>
                <field name="fixative"/>
                <field name="collected_at"/>
                <field name="received_at"/>
                <field name="cassette_count"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_lab_pathology_specimen_form" model="ir.ui.view">
        <field name="name">lab.pathology.specimen.form</field>
        <field name="model">lab.pathology.specimen</field>
        <field name="arch" type="xml">
            <form string="Pathology Specimen">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="case_id"/>
                            <field name="specimen_type"/>
                            <field name="specimen_site"/>
                            <field name="container_no"/>
                            <field name="fixative"/>
                        </group>
                        <group>
                            <field name="collected_at"/>
                            <field name="received_at"/>
                            <field name="cassette_count"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="gross_note" widget="html"/>
                    </group>
                    <notebook>
                        <page string="Slides">
                            <field name="slide_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="block_id"/>
                                    <field name="stain_method"/>
                                    <field name="stain_result"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Images">
                            <field name="image_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="magnification"/>
                                    <field name="capture_datetime"/>
                                    <field name="slide_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lab_pathology_slide_list" model="ir.ui.view">
        <field name="name">lab.pathology.slide.list</field>
        <field name="model">lab.pathology.slide</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="specimen_id"/>
                <field name="block_id"/>
                <field name="stain_method"/>
                <field name="stain_result"/>
                <field name="state"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_lab_pathology_slide_form" model="ir.ui.view">
        <field name="name">lab.pathology.slide.form</field>
        <field name="model">lab.pathology.slide</field>
        <field name="arch" type="xml">
            <form string="Pathology Slide">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="specimen_id"/>
                            <field name="block_id"/>
                            <field name="stain_method"/>
                            <field name="stain_result"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="microscopic_note" widget="html"/>
                    </group>
                    <group>
                        <field name="image_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="magnification"/>
                                <field name="capture_datetime"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lab_pathology_image_list" model="ir.ui.view">
        <field name="name">lab.pathology.image.list</field>
        <field name="model">lab.pathology.image</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="case_id"/>
                <field name="specimen_id"/>
                <field name="slide_id"/>
                <field name="magnification"/>
                <field name="capture_datetime"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_lab_pathology_image_form" model="ir.ui.view">
        <field name="name">lab.pathology.image.form</field>
        <field name="model">lab.pathology.image</field>
        <field name="arch" type="xml">
            <form string="Pathology Image">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="case_id"/>
                            <field name="specimen_id"/>
                            <field name="slide_id"/>
                            <field name="magnification"/>
                            <field name="capture_datetime"/>
                        </group>
                        <group>
                            <field name="image_1920" widget="image" class="oe_avatar"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lab_pathology_case" model="ir.actions.act_window">
        <field name="name">Pathology Cases</field>
        <field name="res_model">lab.pathology.case</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_pathology_specimen" model="ir.actions.act_window">
        <field name="name">Pathology Specimens</field>
        <field name="res_model">lab.pathology.specimen</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_pathology_slide" model="ir.actions.act_window">
        <field name="name">Pathology Slides</field>
        <field name="res_model">lab.pathology.slide</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_pathology_image" model="ir.actions.act_window">
        <field name="name">Pathology Images</field>
        <field name="res_model">lab.pathology.image</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_laboratory_pathology" name="Pathology" parent="menu_laboratory_operations" sequence="35"/>
    <menuitem id="menu_lab_pathology_case" name="Pathology Cases" parent="menu_laboratory_pathology" action="action_lab_pathology_case" sequence="10"/>
    <menuitem id="menu_lab_pathology_specimen" name="Pathology Specimens" parent="menu_laboratory_pathology" action="action_lab_pathology_specimen" sequence="20"/>
    <menuitem id="menu_lab_pathology_slide" name="Pathology Slides" parent="menu_laboratory_pathology" action="action_lab_pathology_slide" sequence="30"/>
    <menuitem id="menu_lab_pathology_image" name="Pathology Images" parent="menu_laboratory_pathology" action="action_lab_pathology_image" sequence="40"/>

    <record id="view_lab_sample_form_inherit_pathology" model="ir.ui.view">
        <field name="name">lab.sample.form.inherit.pathology</field>
        <field name="model">lab.sample</field>
        <field name="inherit_id" ref="laboratory_management.view_lab_sample_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_pathology_case" icon="fa-stethoscope" invisible="pathology_case_count == 0">
                    <field name="pathology_case_count" widget="statinfo" string="Pathology Case"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_pathology_case" type="object" string="Create Pathology Case" invisible="pathology_case_count &gt; 0"/>
                <button name="action_view_pathology_case" type="object" string="Open Pathology Case" invisible="pathology_case_count == 0"/>
            </xpath>
        </field>
    </record>
</odoo>
