<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_control_center_wizard_form" model="ir.ui.view">
        <field name="name">lab.control.center.wizard.form</field>
        <field name="model">lab.control.center.wizard</field>
        <field name="arch" type="xml">
            <form string="Lab Control Center" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="flow_html" widget="html" nolabel="1" readonly="1"/>
                    </group>

                    <group string="Quick Start Actions" col="6">
                        <button name="action_open_new_request" type="object" string="New Test Request" class="btn-primary"/>
                        <button name="action_open_requests_all" type="object" string="All Requests"/>
                        <button name="action_open_requests_triage" type="object" string="Requests to Triage"/>
                        <button name="action_open_requests_quote" type="object" string="Requests to Quote"/>
                        <button name="action_open_samples_all" type="object" string="Samples / Accessions"/>
                        <button name="action_open_analysis_queue" type="object" string="Analysis Queue"/>
                        <button name="action_open_samples_to_verify" type="object" string="Results to Verify"/>
                        <button name="action_open_manual_review" type="object" string="Manual Review Queue"/>
                        <button name="action_open_worksheets" type="object" string="Worksheets"/>
                        <button name="action_open_dispatch_unacked" type="object" string="Unacknowledged Dispatches"/>
                        <button name="action_open_qc_runs" type="object" string="QC Runs"/>
                        <button name="action_open_task_board" type="object" string="Task Board"/>
                    </group>

                    <group string="Live Counters">
                        <group string="Request">
                            <field name="request_draft_count" readonly="1"/>
                            <field name="request_triage_count" readonly="1"/>
                            <field name="request_quote_count" readonly="1"/>
                            <field name="request_approved_count" readonly="1"/>
                        </group>
                        <group string="Sample &amp; Review">
                            <field name="sample_received_count" readonly="1"/>
                            <field name="sample_in_progress_count" readonly="1"/>
                            <field name="sample_to_verify_count" readonly="1"/>
                            <field name="sample_overdue_count" readonly="1"/>
                        </group>
                        <group string="Quality &amp; Tasks">
                            <field name="analysis_manual_review_count" readonly="1"/>
                            <field name="report_unacked_count" readonly="1"/>
                            <field name="qc_reject_recent_count" readonly="1"/>
                            <field name="task_open_count" readonly="1"/>
                        </group>
                    </group>

                    <group string="Role Guidance">
                        <field name="guide_html" widget="html" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lab_control_center_wizard" model="ir.actions.act_window">
        <field name="name">Lab Control Center</field>
        <field name="res_model">lab.control.center.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_lab_control_center" name="Control Center" parent="menu_laboratory_root" action="action_lab_control_center_wizard" sequence="1"/>
</odoo>
