<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_instrument_calibration_list" model="ir.ui.view">
        <field name="name">lab.instrument.calibration.list</field>
        <field name="model">lab.instrument.calibration</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'failed' or is_overdue" decoration-warning="state in ('planned','in_progress')" decoration-success="state == 'completed' and result == 'pass'">
                <field name="name"/>
                <field name="instrument_id"/>
                <field name="calibration_type_id"/>
                <field name="planned_date"/>
                <field name="performed_date"/>
                <field name="result"/>
                <field name="next_due_date"/>
                <field name="state"/>
                <field name="is_overdue" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_lab_instrument_calibration_form" model="ir.ui.view">
        <field name="name">lab.instrument.calibration.form</field>
        <field name="model">lab.instrument.calibration</field>
        <field name="arch" type="xml">
            <form string="Instrument Calibration">
                <header>
                    <button name="action_plan" type="object" string="Plan" class="btn-primary" invisible="state not in ('draft','cancel')"/>
                    <button name="action_start" type="object" string="Start" class="btn-primary" invisible="state not in ('draft','planned')"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-primary" invisible="state not in ('planned','in_progress')"/>
                    <button name="action_fail" type="object" string="Fail" invisible="state not in ('planned','in_progress')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('completed','cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,in_progress,completed,failed,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_attachments" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="Evidence"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="instrument_id"/>
                            <field name="equipment_id"/>
                            <field name="calibration_type_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="planned_date"/>
                            <field name="performed_date"/>
                            <field name="performed_by_id"/>
                            <field name="vendor_partner_id"/>
                            <field name="maintenance_request_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="certificate_reference"/>
                            <field name="result"/>
                            <field name="next_due_date" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lab_instrument_calibration_search" model="ir.ui.view">
        <field name="name">lab.instrument.calibration.search</field>
        <field name="model">lab.instrument.calibration</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="instrument_id"/>
                <field name="calibration_type_id"/>
                <field name="result"/>
                <filter name="f_open" string="Open" domain="[('state','in',('draft','planned','in_progress','failed'))]"/>
                <filter name="f_due" string="Overdue" domain="[('is_overdue','=',True)]"/>
                <filter name="f_failed" string="Failed" domain="[('state','=','failed')]"/>
                <separator string="Group By"/>
                <filter name="group_instrument" string="Instrument" context="{'group_by':'instrument_id'}"/>
                <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                <filter name="group_result" string="Result" context="{'group_by':'result'}"/>
            </search>
        </field>
    </record>

    <record id="action_lab_instrument_calibration" model="ir.actions.act_window">
        <field name="name">Calibration Records</field>
        <field name="res_model">lab.instrument.calibration</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lab_instrument_calibration_search"/>
        <field name="context">{'search_default_f_open': 1}</field>
    </record>

    <record id="view_lab_instrument_form_inherit_calibration" model="ir.ui.view">
        <field name="name">lab.instrument.form.inherit.calibration</field>
        <field name="model">lab.instrument</field>
        <field name="inherit_id" ref="laboratory_management.view_lab_instrument_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button" type="object" name="action_view_calibration_records" icon="fa-crosshairs">
                        <field name="calibration_record_count" widget="statinfo" string="Calibrations"/>
                    </button>
                </div>
            </xpath>
            <xpath expr="//group" position="replace">
                <group>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="department"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="equipment_id"/>
                        <field name="responsible_user_id"/>
                        <field name="quality_owner_id"/>
                        <field name="calibration_policy"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Calibration">
                    <group>
                        <group>
                            <field name="calibration_interval_days"/>
                            <field name="calibration_warning_days"/>
                            <field name="calibration_grace_days"/>
                            <field name="block_run_if_calibration_overdue"/>
                        </group>
                        <group>
                            <field name="last_calibration_date"/>
                            <field name="next_calibration_date" readonly="1"/>
                            <field name="calibration_status" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="calibration_note"/>
                    </group>
                    <group>
                        <button name="action_create_calibration_record" type="object" string="New Calibration Record" class="btn-primary"/>
                    </group>
                    <field name="calibration_record_ids">
                        <list editable="bottom" default_order="planned_date desc">
                            <field name="name" readonly="1"/>
                            <field name="planned_date"/>
                            <field name="performed_date"/>
                            <field name="calibration_type_id"/>
                            <field name="result"/>
                            <field name="state"/>
                            <field name="next_due_date" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_lab_instrument_run_form_inherit_calibration" model="ir.ui.view">
        <field name="name">lab.instrument.run.form.inherit.calibration</field>
        <field name="model">lab.instrument.run</field>
        <field name="inherit_id" ref="laboratory_management.view_lab_instrument_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='instrument_id']" position="after">
                <field name="instrument_calibration_status" readonly="1"/>
                <field name="instrument_next_calibration_date" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_maintenance_equipment_form_inherit_lab_instrument" model="ir.ui.view">
        <field name="name">maintenance.equipment.form.inherit.lab.instrument</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_lab_instrument" icon="fa-flask">
                    <field name="lab_instrument_count" widget="statinfo" string="Lab Instrument"/>
                </button>
            </xpath>
            <xpath expr="//page[@name='product_information']/group/group[1]" position="inside">
                <button name="action_create_lab_instrument" type="object" string="Create Lab Instrument" class="btn-primary" invisible="lab_instrument_count != 0"/>
            </xpath>
        </field>
    </record>

    <record id="view_maintenance_request_form_inherit_recalibration" model="ir.ui.view">
        <field name="name">maintenance.request.form.inherit.recalibration</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Recalibration Control">
                    <group>
                        <field name="lab_instrument_id" readonly="1"/>
                        <field name="requires_recalibration"/>
                        <field name="recalibration_type_id" invisible="not requires_recalibration"/>
                        <field name="calibration_record_id" readonly="1" invisible="not calibration_record_id"/>
                    </group>
                    <group>
                        <field name="recalibration_note" placeholder="Describe why recalibration is required after this maintenance." invisible="not requires_recalibration"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_lab_instrument_calibration" name="Calibration Records" parent="menu_lab_config_inventory" action="action_lab_instrument_calibration" sequence="52"/>
</odoo>
