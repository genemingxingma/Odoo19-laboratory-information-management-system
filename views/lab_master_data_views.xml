    <record id="action_lab_calibration_type" model="ir.actions.act_window">
        <field name="name">Calibration Types</field>
        <field name="res_model">lab.calibration.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lab_master_data_root" name="Master Data" parent="menu_lab_config_org" sequence="5"/>
    <menuitem id="menu_lab_department_type" name="Departments" parent="menu_lab_master_data_root" action="action_lab_department_type" sequence="10"/>
    <menuitem id="menu_lab_sample_type" name="Sample Types" parent="menu_lab_master_data_root" action="action_lab_sample_type" sequence="20"/>
    <menuitem id="menu_lab_priority_type" name="Priorities" parent="menu_lab_master_data_root" action="action_lab_priority_type" sequence="30"/>
    <menuitem id="menu_lab_request_type" name="Request Types" parent="menu_lab_master_data_root" action="action_lab_request_type" sequence="40"/>
    <menuitem id="menu_lab_result_unit" name="Result Units" parent="menu_lab_master_data_root" action="action_lab_result_unit" sequence="50"/>
    <menuitem id="menu_lab_risk_type" name="Risk Types" parent="menu_lab_master_data_root" action="action_lab_risk_type" sequence="60"/>
    <menuitem id="menu_lab_waste_type" name="Waste Types" parent="menu_lab_master_data_root" action="action_lab_waste_type" sequence="70"/>
    <menuitem id="menu_lab_waste_treatment_method" name="Waste Treatment Methods" parent="menu_lab_master_data_root" action="action_lab_waste_treatment_method" sequence="80"/>
    <menuitem id="menu_lab_calibration_type" name="Calibration Types" parent="menu_lab_master_data_root" action="action_lab_calibration_type" sequence="90"/>
</odoo>
