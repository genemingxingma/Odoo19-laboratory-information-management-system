<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_department_type_list" model="ir.ui.view">
        <field name="name">lab.department.type.list</field>
        <field name="model">lab.department.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_sample_type_list" model="ir.ui.view">
        <field name="name">lab.sample.type.list</field>
        <field name="model">lab.sample.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_priority_type_list" model="ir.ui.view">
        <field name="name">lab.priority.type.list</field>
        <field name="model">lab.priority.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_request_type_list" model="ir.ui.view">
        <field name="name">lab.request.type.list</field>
        <field name="model">lab.request.type</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="name"/>
                <field name="code"/>
                <field name="allowed_service_count" string="Services"/>
                <field name="allowed_profile_count" string="Profiles"/>
            </list>
        </field>
    </record>

    <record id="view_lab_request_type_form" model="ir.ui.view">
        <field name="name">lab.request.type.form</field>
        <field name="model">lab.request.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="code" readonly="1"/>
                            <field name="allowed_service_count" readonly="1"/>
                            <field name="allowed_profile_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Request Type Catalog Scope">
                        <field name="exclude_selected_services"/>
                        <field
                            name="allowed_service_ids"
                            widget="many2many_tags"
                            domain="[('active','=',True), ('company_id', '=', company_id), ('profile_only', '=', False), ('id', 'not in', allowed_service_ids)]"
                        />
                        <field name="exclude_selected_profiles"/>
                        <field
                            name="allowed_profile_ids"
                            widget="many2many_tags"
                            domain="[('active','=',True), ('company_id', '=', company_id), ('id', 'not in', allowed_profile_ids)]"
                        />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lab_result_unit_list" model="ir.ui.view">
        <field name="name">lab.result.unit.list</field>
        <field name="model">lab.result.unit</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_risk_type_list" model="ir.ui.view">
        <field name="name">lab.risk.type.list</field>
        <field name="model">lab.risk.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_waste_type_list" model="ir.ui.view">
        <field name="name">lab.waste.type.list</field>
        <field name="model">lab.waste.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_waste_treatment_method_list" model="ir.ui.view">
        <field name="name">lab.waste.treatment.method.list</field>
        <field name="model">lab.waste.treatment.method</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_calibration_type_list" model="ir.ui.view">
        <field name="name">lab.calibration.type.list</field>
        <field name="model">lab.calibration.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_lab_department_type" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">lab.department.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_sample_type" model="ir.actions.act_window">
        <field name="name">Sample Types</field>
        <field name="res_model">lab.sample.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_priority_type" model="ir.actions.act_window">
        <field name="name">Priorities</field>
        <field name="res_model">lab.priority.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_request_type" model="ir.actions.act_window">
        <field name="name">Request Types</field>
        <field name="res_model">lab.request.type</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("code", "in", ["individual", "institution"])]</field>
        <field name="context">{"create": 0, "delete": 0}</field>
    </record>

    <record id="action_lab_result_unit" model="ir.actions.act_window">
        <field name="name">Result Units</field>
        <field name="res_model">lab.result.unit</field>
        <field name="view_mode">list,form</field>
