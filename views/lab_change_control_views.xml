<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_change_control_list" model="ir.ui.view">
        <field name="name">lab.change.control.list</field>
        <field name="model">lab.change.control</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'rejected'" decoration-warning="state in ('approval', 'implementation', 'validation')" decoration-success="state in ('effective', 'closed')">
                <field name="name"/>
                <field name="title"/>
                <field name="change_type"/>
                <field name="risk_level"/>
                <field name="owner_user_id"/>
                <field name="approver_user_id"/>
                <field name="target_effective_date"/>
                <field name="effective_ready"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_lab_change_control_form" model="ir.ui.view">
        <field name="name">lab.change.control.form</field>
        <field name="model">lab.change.control</field>
        <field name="arch" type="xml">
            <form string="Laboratory Change Control">
                <header>
                    <button name="action_submit_impact" type="object" string="Start Assessment" class="btn-primary" invisible="state not in ('draft','rejected')"/>
                    <button name="action_request_approval" type="object" string="Request Approval" class="btn-primary" invisible="state not in ('draft','impact','rejected')"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" groups="laboratory_management.group_lab_quality_manager" invisible="state != 'approval'"/>
                    <button name="action_reject" type="object" string="Reject" groups="laboratory_management.group_lab_quality_manager" invisible="state not in ('approval','approved','implementation','validation')"/>
                    <button name="action_start_implementation" type="object" string="Start Implementation" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_mark_implemented" type="object" string="Mark Implemented" class="btn-primary" invisible="state not in ('approved','implementation')"/>
                    <button name="action_mark_validated" type="object" string="Mark Validation Ready" class="btn-primary" invisible="state not in ('implementation','validation')"/>
                    <button name="action_mark_effective" type="object" string="Set Effective" class="btn-primary" invisible="state not in ('approved','implementation','validation')"/>
                    <button name="action_close" type="object" string="Close" class="btn-primary" invisible="state != 'effective'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('closed','cancel')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state not in ('cancel','rejected')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,impact,approval,approved,implementation,validation,effective,closed,rejected,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_attachments" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo" string="Evidence"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_governance_evidence" icon="fa-link">
                            <field name="evidence_count" widget="statinfo" string="Evidence Links"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="title"/>
                            <field name="change_type"/>
                            <field name="risk_level"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="owner_user_id"/>
                            <field name="approver_user_id"/>
                            <field name="quality_user_id"/>
                            <field name="requested_date"/>
                            <field name="target_effective_date"/>
                        </group>
                    </group>
                    <group string="Operational Controls">
                        <group>
                            <field name="digital_record_only"/>
                            <field name="block_release"/>
                            <field name="approval_reference" invisible="not digital_record_only"/>
                            <field name="approval_record_ref" invisible="not digital_record_only"/>
                            <field name="electronic_signature_reference" invisible="not digital_record_only"/>
                            <field name="signature_record_ref" invisible="not digital_record_only"/>
                            <field name="document_review_required"/>
                            <field name="document_review_complete"/>
                        </group>
                        <group>
                            <field name="controlled_document_reference" invisible="not digital_record_only and not document_review_required"/>
                            <field name="controlled_document_ref" invisible="not digital_record_only and not document_review_required"/>
                            <field name="training_required"/>
                            <field name="training_ack_complete"/>
                            <field name="validation_required"/>
                            <field name="validation_evidence_complete"/>
                            <field name="implementation_complete"/>
                        </group>
                    </group>
                    <group string="Effective Readiness">
                        <group>
                            <field name="effective_ready" readonly="1"/>
                            <field name="effective_block_reason" readonly="1" invisible="not effective_block_reason"/>
                        </group>
                        <group>
                            <field name="approved_at" readonly="1"/>
                            <field name="implemented_at" readonly="1"/>
                            <field name="validated_at" readonly="1"/>
                            <field name="effective_at" readonly="1"/>
                            <field name="closed_at" readonly="1"/>
                            <field name="rejected_at" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assessment">
                            <group>
                                <field name="reason"/>
                                <field name="scope_summary"/>
                                <field name="impact_assessment"/>
                                <field name="implementation_plan"/>
                                <field name="validation_plan" invisible="not validation_required"/>
                                <field name="training_plan" invisible="not training_required"/>
                                <field name="rollback_plan"/>
                                <field name="effectiveness_note"/>
                                <field name="reject_reason" invisible="state not in ('rejected','approval','approved','implementation','validation')"/>
                            </group>
                        </page>
                        <page string="Affected Objects">
                            <group>
                                <group>
                                    <field name="service_ids" widget="many2many_tags"/>
                                    <field name="profile_ids" widget="many2many_tags"/>
                                    <field name="report_template_ids" widget="many2many_tags"/>
                                    <field name="sop_ids" widget="many2many_tags"/>
                                    <field name="risk_register_ids" widget="many2many_tags" readonly="1"/>
                                </group>
                                <group>
                                    <field name="interface_endpoint_ids" widget="many2many_tags"/>
                                    <field name="instrument_ids" widget="many2many_tags"/>
                                    <field name="reagent_lot_ids" widget="many2many_tags"/>
                                    <field name="method_validation_ids" widget="many2many_tags"/>
                                    <field name="training_session_ids" widget="many2many_tags" invisible="not training_required"/>
                                    <field name="nonconformance_ids" widget="many2many_tags" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <button name="action_create_linked_risk" type="object" string="Create Linked Risk" class="btn-secondary" invisible="risk_register_ids"/>
                                <button name="action_create_linked_nonconformance" type="object" string="Create Linked CAPA" class="btn-secondary" invisible="nonconformance_ids"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lab_change_control_search" model="ir.ui.view">
        <field name="name">lab.change.control.search</field>
        <field name="model">lab.change.control</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="title"/>
            </search>
        </field>
    </record>

    <record id="action_lab_change_control" model="ir.actions.act_window">
        <field name="name">Change Control</field>
        <field name="res_model">lab.change.control</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lab_change_control_search"/>
        <field name="context">{'search_default_f_open': 1}</field>
    </record>

    <menuitem id="menu_lab_change_control" name="Change Control" parent="menu_lab_quality_compliance" action="action_lab_change_control" sequence="12" groups="laboratory_management.group_lab_reviewer"/>
</odoo>
