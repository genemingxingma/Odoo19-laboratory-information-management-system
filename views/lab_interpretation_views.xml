<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_interpretation_profile_list" model="ir.ui.view">
        <field name="name">lab.interpretation.profile.list</field>
        <field name="model">lab.interpretation.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="service_match_mode"/>
                <field name="minimum_required_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_interpretation_profile_form" model="ir.ui.view">
        <field name="name">lab.interpretation.profile.form</field>
        <field name="model">lab.interpretation.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="service_match_mode"/>
                            <field name="minimum_required_count"/>
                            <field name="positive_summary_template"/>
                            <field name="negative_summary_text"/>
                            <field name="inconclusive_summary_text"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <notebook>
                        <page string="Rules">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="active"/>
                                    <field name="service_id"/>
                                    <field name="label"/>
                                    <field name="evaluation_mode"/>
                                    <field name="threshold_float"/>
                                    <field name="threshold_text"/>
                                    <field name="include_in_detected"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lab_interpretation_profile_search" model="ir.ui.view">
        <field name="name">lab.interpretation.profile.search</field>
        <field name="model">lab.interpretation.profile</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter name="filter_active" string="Active" domain="[('active','=',True)]"/>
                <filter name="group_mode" string="Group by Match Mode" context="{'group_by': 'service_match_mode'}"/>
            </search>
        </field>
    </record>

    <record id="action_lab_interpretation_profile" model="ir.actions.act_window">
        <field name="name">Interpretation Profiles</field>
        <field name="res_model">lab.interpretation.profile</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lab_interpretation_profile_search"/>
    </record>

    <menuitem
        id="menu_lab_interpretation_profile"
        name="Interpretation Profiles"
        parent="menu_lab_config_catalog"
        action="action_lab_interpretation_profile"
        sequence="45"
    />
</odoo>
