<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lab_physician_department_list" model="ir.ui.view">
        <field name="name">lab.physician.department.list</field>
        <field name="model">lab.physician.department</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_physician_department_form" model="ir.ui.view">
        <field name="name">lab.physician.department.form</field>
        <field name="model">lab.physician.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lab_physician_list" model="ir.ui.view">
        <field name="name">lab.physician.list</field>
        <field name="model">lab.physician</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="license_no"/>
                <field name="lab_physician_department_id"/>
                <field name="institution_partner_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lab_physician_form" model="ir.ui.view">
        <field name="name">lab.physician.form</field>
        <field name="model">lab.physician</field>
        <field name="arch" type="xml">
            <form string="Lab Physician">
                <sheet>
                    <group>
                        <field name="name" required="1"/>
                        <field name="code"/>
                        <field name="license_no"/>
                        <field name="lab_physician_department_id"/>
                        <field name="institution_partner_id"/>
                        <field name="specialty"/>
                        <field name="title"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="notify_by_email"/>
                        <field name="notify_by_sms"/>
                        <field name="signature_image" widget="image" class="oe_avatar"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lab_physician_department" model="ir.actions.act_window">
        <field name="name">Physician Departments</field>
        <field name="res_model">lab.physician.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_lab_physician_contact" model="ir.actions.act_window">
        <field name="name">Physicians</field>
        <field name="res_model">lab.physician</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

    <menuitem id="menu_lab_physician_department"
              name="Physician Departments"
              parent="menu_lab_master_data_root"
              action="action_lab_physician_department"
              sequence="45"/>
    <menuitem id="menu_lab_physician_contact"
              name="Physicians"
              parent="menu_lab_master_data_root"
              action="action_lab_physician_contact"
              sequence="46"/>
</odoo>
