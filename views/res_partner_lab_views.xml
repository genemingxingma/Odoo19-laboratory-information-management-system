<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_lab_report_template" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.lab.report.template</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field
                    name="lab_default_report_template_id"
                    string="Default Lab Report Template"
                    invisible="not is_company"
                    options="{'no_open': False, 'no_create': False}"
                />
            </xpath>
        </field>
    </record>
</odoo>
