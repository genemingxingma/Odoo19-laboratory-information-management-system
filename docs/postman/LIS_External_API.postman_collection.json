{
  "info": {
    "name": "LIS Integration APIs (External + Interface)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "AI-friendly collection for external institution REST API and LIS/HIS interface channel API"
  },
  "item": [
    {
      "name": "External Institution API",
      "item": [
        {
          "name": "Create Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/api/v1/{{endpoint_code}}/requests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_uid\": \"HIS-REQ-{{timestamp}}\",\n  \"priority\": \"routine\",\n  \"sample_type\": \"swab\",\n  \"clinical_note\": \"API intake request\",\n  \"patient\": {\n    \"name\": \"API Patient\",\n    \"identifier\": \"ID-001\",\n    \"gender\": \"female\",\n    \"birthdate\": \"1992-01-01\"\n  },\n  \"physician\": {\n    \"name\": \"Dr. External\",\n    \"partner_ref\": \"PHY-001\"\n  },\n  \"lines\": [\n    {\n      \"line_type\": \"service\",\n      \"service_code\": \"STD_CT\",\n      \"quantity\": 1,\n      \"specimen_ref\": \"SP1\",\n      \"specimen_barcode\": \"BC-{{timestamp}}\",\n      \"specimen_sample_type\": \"swab\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Query Request",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/api/v1/{{endpoint_code}}/requests/{{request_no}}"
          }
        },
        {
          "name": "Query Sample Results",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/api/v1/{{endpoint_code}}/samples/{{accession}}/results"
          }
        },
        {
          "name": "Download PDF Report",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/api/v1/{{endpoint_code}}/samples/{{accession}}/report/pdf"
          }
        }
      ]
    },
    {
      "name": "LIS/HIS Interface API",
      "item": [
        {
          "name": "Inbound JSONRPC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/interface/inbound/{{interface_endpoint_code}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"call\",\n  \"params\": {\n    \"message_type\": \"order\",\n    \"external_uid\": \"EXT-{{timestamp}}\",\n    \"payload\": {\n      \"order_number\": \"ORD-{{timestamp}}\",\n      \"patient\": {\"name\": \"Demo\"}\n    }\n  },\n  \"id\": 1\n}"
            }
          }
        },
        {
          "name": "Inbound Raw (REST JSON)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/interface/inbound/{{interface_endpoint_code}}/raw",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message_type\": \"order\",\n  \"external_uid\": \"RAW-{{timestamp}}\",\n  \"payload\": {\n    \"order_no\": \"ORD-RAW-{{timestamp}}\"\n  }\n}"
            }
          }
        },
        {
          "name": "Outbound ACK Callback",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": "{{base_url}}/lab/interface/outbound/{{interface_endpoint_code}}/ack",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"call\",\n  \"params\": {\n    \"ack_code\": \"AA\",\n    \"job_name\": \"IFJ-0001\",\n    \"external_uid\": \"EXT-{{timestamp}}\",\n    \"message\": \"accepted\",\n    \"payload\": {\n      \"remote_id\": \"ACK-001\"\n    }\n  },\n  \"id\": 2\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8069" },
    { "key": "endpoint_code", "value": "ext_hospital_demo" },
    { "key": "interface_endpoint_code", "value": "if_rest_demo" },
    { "key": "api_key", "value": "DEMO-HOSP-API-KEY-2026" },
    { "key": "request_no", "value": "TRQ2602-00320" },
    { "key": "accession", "value": "ACC2602-00318" },
    { "key": "timestamp", "value": "20260222120000" }
  ]
}
